# --- Database -----------------------------------------------------------
# PostgreSQL connection string. In production, use a pooled connection
# (e.g. PgBouncer, Neon/Supabase pooled URL) — Prisma opens a connection
# per serverless invocation otherwise.
DATABASE_URL="postgresql://user:password@localhost:5432/jall_technologies"

# --- Auth (NextAuth v5) ---------------------------------------------------
# Generate with: openssl rand -base64 32
# Required in production — without it, sessions can't be signed/verified.
AUTH_SECRET="replace-with-a-random-32-byte-base64-string"

# The canonical URL of the deployed app. Used to build absolute links in
# emails (password reset, project update notifications) and by NextAuth.
NEXTAUTH_URL="http://localhost:3000"

# --- Email (Resend) --------------------------------------------------------
# Without this set, the app logs emails to the console instead of sending
# them — fine for local dev, NOT fine for production (password resets and
# client notifications will silently never arrive).
RESEND_API_KEY=""
EMAIL_FROM="Jall Technologies <notifications@jalltechnologies.com>"

# --- Public app URL (client-side) ------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
