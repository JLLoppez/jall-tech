# PostgreSQL connection string (Prisma)
# Local:      postgresql://user:password@localhost:5432/jall_technologies
# Vercel/Neon: get from your Postgres provider (Neon, Supabase, Render, RDS, etc.)
DATABASE_URL="postgresql://user:password@localhost:5432/jall_technologies"

# Auth.js (NextAuth v5) \u2014 generate with: npx auth secret
# or: openssl rand -base64 32
AUTH_SECRET="replace-with-a-random-32-byte-secret"

# Only needed in production if your deployment URL isn't auto-detected
# NEXTAUTH_URL="https://jalltechnologies.com"

# App URL (used for metadata / absolute links in production)
NEXT_PUBLIC_SITE_URL="https://jalltechnologies.com"

# Optional \u2014 wire up if you add email notifications on new contact submissions
# RESEND_API_KEY=""
# CONTACT_NOTIFICATION_EMAIL="hello@jalltechnologies.com"
